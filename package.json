{
  "name": "@dokall/link-preview",
  "version": "1.0.8",
  "description": "Direct link unfurling (Open Graph + platform oEmbed) without third-party preview APIs",
  "license": "MIT",
  "author": "Dokall <dev@dokall.com> (https://dokall.com)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dokalldotcom/link-preview.git"
  },
  "homepage": "https://dokall.com/tools/link-preview",
  "bugs": {
    "url": "https://github.com/dokalldotcom/link-preview/issues"
  },
  "keywords": [
    "link-preview",
    "unfurl",
    "open-graph",
    "og-tags",
    "oembed",
    "metadata",
    "url-preview"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "example": "npm run build && node examples/basic.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
